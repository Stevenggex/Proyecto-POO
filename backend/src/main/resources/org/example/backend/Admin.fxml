<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="768.0" prefWidth="1280.0" stylesheets="/Estilos/style-dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="modelo.AdminController">

    <left>
        <VBox prefWidth="240.0" spacing="15.0" styleClass="sidebar">
            <padding>
                <Insets bottom="24.0" left="16.0" right="16.0" top="24.0" />
            </padding>
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label styleClass="brand-title" text="QUEST_LOG">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <Label opacity="0.7" styleClass="text-muted" text="Administrador">
                            <font><Font size="11.0" /></font>
                        </Label>
                    </children>
                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                </VBox>

                <Button fx:id="dashboardBtn" maxWidth="1.7976931348623157E308" onAction="#handleDashboard" prefHeight="40.0" styleClass="nav-button" text="Panel" />
                <Button fx:id="inventoryBtn" maxWidth="1.7976931348623157E308" onAction="#handleInventory" prefHeight="40.0" styleClass="nav-button" text="Inventario" />
                <Button fx:id="searchBtn" maxWidth="1.7976931348623157E308" onAction="#handleBuscar" prefHeight="40.0" styleClass="nav-button" text="Buscar Productos" />

                <VBox alignment="BOTTOM_CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="logoutBtn" maxWidth="1.7976931348623157E308" onAction="#handleLogout" prefHeight="40.0" styleClass="nav-button" text="Cerrar Sesion" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="64.0" style="-fx-border-color: transparent transparent #4d4354 transparent; -fx-border-width: 1px;">
                    <padding><Insets left="24.0" right="24.0" /></padding>
                    <children>
                        <TextField fx:id="busquedaField" prefWidth="250.0" promptText="Buscar productos..." style="-fx-background-radius: 20px; -fx-border-radius: 20px;" styleClass="text-input-custom" />
                    </children>
                </HBox>

                <HBox spacing="24.0" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                    <children>

                        <VBox prefWidth="420.0" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="text-primary-color" text="✏️">
                                            <font><Font size="18.0" /></font>
                                        </Label>
                                        <Label fx:id="formTitle" styleClass="text-primary-color" text="Editar Producto">
                                            <font><Font name="System Bold" size="20.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>

                                <VBox spacing="15.0" styleClass="glass-panel-cyan">
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="text-muted" text="Nombre del producto" />
                                                <TextField fx:id="nombreField" prefHeight="38.0" promptText="Ingrese el titulo del juego" styleClass="text-input-custom" />
                                            </children>
                                        </VBox>

                                        <HBox spacing="15.0">
                                            <children>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="text-muted" text="Precio (USD)" />
                                                        <TextField fx:id="precioField" prefHeight="38.0" promptText="$ 0.00" styleClass="text-input-custom" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="text-muted" text="Cantidad en Stock" />
                                                        <TextField fx:id="stockField" prefHeight="38.0" promptText="0" styleClass="text-input-custom" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="text-muted" text="Categoria" />
                                                <ComboBox fx:id="categoriaCombo" maxWidth="1.7976931348623157E308" prefHeight="38.0" styleClass="text-input-custom">
                                                    <items>
                                                        <FXCollections fx:factory="observableArrayList">
                                                             <String fx:value="Accion / RPG" />
                                                             <String fx:value="Estrategia" />
                                                             <String fx:value="Simulador" />
                                                             <String fx:value="Terror" />
                                                            <String fx:value="Indie" />
                                                        </FXCollections>
                                                    </items>
                                                </ComboBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="text-muted" text="Pequena Descripcion" />
                                                <TextArea fx:id="descripcionArea" prefHeight="80.0" promptText="Describa la experiencia del juego..." styleClass="text-input-custom" wrapText="true" />
                                            </children>
                                        </VBox>

                                        <VBox fx:id="imagenDropZone" alignment="CENTER" prefHeight="80.0" onMouseClicked="#seleccionarImagen" style="-fx-border-color: #4d4354; -fx-border-style: dashed; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-cursor: hand;">
                                            <children>
                                                <ImageView fx:id="imagenPreview" fitHeight="60.0" fitWidth="60.0" preserveRatio="true" visible="false" />
                                                <Label fx:id="imagenLabel" styleClass="text-muted" text="Haga clic para cambiar la imagen" />
                                            </children>
                                        </VBox>

                                        <Button fx:id="registrarBtn" maxWidth="1.7976931348623157E308" onAction="#handleRegistrar" prefHeight="45.0" styleClass="btn-primary-neon" text="Actualizar Producto" disable="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Label styleClass="text-secondary-color" text="📦">
                                                    <font><Font size="18.0" /></font>
                                                </Label>
                                                <Label styleClass="text-secondary-color" text="Inventario de Productos">
                                                    <font><Font name="System Bold" size="20.0" /></font>
                                                </Label>
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                                    <content>
                                        <GridPane fx:id="inventoryGrid" hgap="15.0" vgap="15.0">
                                        </GridPane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
