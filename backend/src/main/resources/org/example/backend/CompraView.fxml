<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="768.0" prefWidth="1280.0" stylesheets="/Estilos/style-dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="modelo.CompraController">

    <left>
        <VBox prefWidth="220.0" spacing="12.0" styleClass="sidebar">
            <padding><Insets bottom="24.0" left="16.0" right="16.0" top="24.0" /></padding>
            <children>
                <Label styleClass="brand-title" text="QUEST_LOG">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
                <Label opacity="0.6" styleClass="text-muted" text="Cliente">
                    <font><Font size="11.0" /></font>
                </Label>
                <Separator opacity="0.3" />
                <Button maxWidth="1.7976931348623157E308" onAction="#handleCatalogo" prefHeight="38.0" styleClass="nav-button" text="Catalogo" />
                <Button maxWidth="1.7976931348623157E308" onAction="#handleMisCompras" prefHeight="38.0" styleClass="nav-button" text="Mis Compras" />
                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleLogout" prefHeight="38.0" styleClass="nav-button" text="Cerrar Sesion" />
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox BorderPane.alignment="CENTER">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-border-color: transparent transparent #4d4354 transparent; -fx-border-width: 1px;">
                    <padding><Insets left="24.0" right="24.0" /></padding>
                    <children>
                        <Label styleClass="text-white" text="🛒 Registrar Compra">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="text-muted" text="Cliente / Nueva Compra" />
                    </children>
                </HBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>
                    <children>

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                            <children>

                                <TextField fx:id="searchField" prefHeight="38.0" promptText="Buscar videojuego..." styleClass="text-input-custom" />

                                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                                    <content>
                                        <GridPane fx:id="productGrid" hgap="15.0" vgap="15.0">
                                            <columnConstraints>
                                                <ColumnConstraints />
                                                <ColumnConstraints />
                                                <ColumnConstraints />
                                            </columnConstraints>
                                            <rowConstraints><RowConstraints /></rowConstraints>

                                        </GridPane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <VBox prefWidth="420.0" spacing="15.0">
                            <children>

                                <VBox spacing="12.0" styleClass="glass-panel-cyan">
                                    <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                                    <children>
                                        <Label styleClass="text-white" text="Datos del Cliente">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                        <TextField fx:id="nombreClienteField" promptText="Nombre completo" styleClass="text-input-custom" />
                                        <TextField fx:id="direccionField" promptText="Dirección" styleClass="text-input-custom" />
                                        <HBox spacing="10.0">
                                            <TextField fx:id="correoField" promptText="Correo" styleClass="text-input-custom" HBox.hgrow="ALWAYS" />
                                            <TextField fx:id="telefonoField" promptText="Teléfono" prefWidth="140.0" styleClass="text-input-custom" />
                                        </HBox>
                                        <ComboBox fx:id="pagoCombo" maxWidth="1.7976931348623157E308" promptText="Método de pago..." styleClass="text-input-custom" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0" styleClass="glass-panel-cyan" VBox.vgrow="ALWAYS">
                                    <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <Label styleClass="text-white" text="🧾 Factura">
                                                <font><Font name="System Bold" size="14.0" /></font>
                                            </Label>
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Label fx:id="totalLabel" styleClass="text-secondary-color" text="Total: $0.00">
                                                <font><Font name="System Bold" size="16.0" /></font>
                                            </Label>
                                        </HBox>

                                        <TableView fx:id="facturaTable" prefHeight="200.0" styleClass="text-input-custom" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colProducto" prefWidth="180.0" text="Producto" />
                                                <TableColumn fx:id="colCant" prefWidth="60.0" text="Cant." />
                                                <TableColumn fx:id="colPrecio" prefWidth="80.0" text="Precio" />
                                                <TableColumn fx:id="colSubtotal" prefWidth="80.0" text="Subtotal" />
                                            </columns>
                                        </TableView>

                                        <Button fx:id="registrarCompraBtn" maxWidth="1.7976931348623157E308" onAction="#handleRegistrarCompra" prefHeight="42.0" styleClass="btn-primary-neon" text="✅ Registrar Compra" />
                                    </children>
                                </VBox>

                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>
