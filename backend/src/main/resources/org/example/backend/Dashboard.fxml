<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="768.0" prefWidth="1280.0" stylesheets="/Estilos/style-dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.backend.DashboardController">

    <left>
        <VBox prefWidth="240.0" spacing="15.0" styleClass="sidebar">
            <padding>
                <Insets bottom="24.0" left="16.0" right="16.0" top="24.0" />
            </padding>
            <children>
                <!-- Logo / Brand -->
                <VBox spacing="2.0">
                    <children>
                        <Label styleClass="brand-title" text="QUEST_LOG">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Label opacity="0.7" styleClass="text-muted" text="Level 42 Admin">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </children>
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </VBox>

                <Button fx:id="dashboardBtn" maxWidth="1.7976931348623157E308" onAction="#handleDashboard" prefHeight="40.0" styleClass="nav-button" text="Panel" />
                <Button fx:id="inventoryBtn" maxWidth="1.7976931348623157E308" onAction="#handleInventory" prefHeight="40.0" styleClass="nav-button" text="Inventario" />
                <Button fx:id="addProductBtn" maxWidth="1.7976931348623157E308" onAction="#handleAddProduct" prefHeight="40.0" text="Añadir Producto">
                    <styleClass>
                        <String fx:value="nav-button" />
                        <String fx:value="nav-button-active" />
                    </styleClass>
                </Button>
                <Button fx:id="editBtn" maxWidth="1.7976931348623157E308" onAction="#handleEditar" prefHeight="40.0" styleClass="nav-button" text="Editar Producto" />
                <Button fx:id="deleteBtn" maxWidth="1.7976931348623157E308" onAction="#handleEliminar" prefHeight="40.0" styleClass="nav-button" text="Eliminar Producto" />

                <VBox alignment="BOTTOM_CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="searchBtn" maxWidth="1.7976931348623157E308" onAction="#handleBuscar" prefHeight="40.0" styleClass="nav-button" text="Buscar Productos" />
                        <Button fx:id="logoutBtn" maxWidth="1.7976931348623157E308" onAction="#handleLogout" prefHeight="40.0" styleClass="nav-button" text="Cerrar Sesion" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox BorderPane.alignment="CENTER">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="64.0" style="-fx-border-color: transparent transparent #4d4354 transparent; -fx-border-width: 1px;">
                    <padding>
                        <Insets left="24.0" right="24.0" />
                    </padding>
                    <children>
                        <TextField fx:id="busquedaField" prefWidth="250.0" promptText="Search data logs..." style="-fx-background-radius: 20px; -fx-border-radius: 20px;" styleClass="text-input-custom" />
                        <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Button style="-fx-background-color: transparent;" styleClass="text-white" text="🔔" />
                                <Button style="-fx-background-color: transparent;" styleClass="text-white" text="❓" />
                                <Label prefHeight="32.0" prefWidth="32.0" style="-fx-background-color: #ddb7ff; -fx-background-radius: 50%;" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <HBox spacing="24.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>

                        <VBox prefWidth="420.0" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label styleClass="text-primary-color" text="➕">
                                            <font><Font size="18.0" /></font>
                                        </Label>
                                        <Label styleClass="text-primary-color" text="Añadir Productos">
                                            <font><Font name="System Bold" size="20.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>

                                <VBox spacing="15.0" styleClass="glass-panel-cyan">
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                    </padding>
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="text-muted" text="Nombre del producto" />
                                                <TextField fx:id="nombreField" prefHeight="38.0" promptText="Enter game title" styleClass="text-input-custom" />
                                            </children>
                                        </VBox>

                                        <HBox spacing="15.0">
                                            <children>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="text-muted" text="Precio (USD)" />
                                                        <TextField fx:id="precioField" prefHeight="38.0" promptText="\$ 0.00" styleClass="text-input-custom" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="text-muted" text="Cantidad en Stock" />
                                                        <TextField fx:id="stockField" prefHeight="38.0" promptText="0" styleClass="text-input-custom" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="text-muted" text="Categoria" />
                                                <ComboBox fx:id="categoriaCombo" maxWidth="1.7976931348623157E308" prefHeight="38.0" styleClass="text-input-custom">
                                                    <items>
                                                        <FXCollections fx:factory="observableArrayList">
                                                            <String fx:value="Action / RPG" />
                                                            <String fx:value="Strategy" />
                                                            <String fx:value="Simulator" />
                                                            <String fx:value="Horror" />
                                                            <String fx:value="Indie" />
                                                        </FXCollections>
                                                    </items>
                                                </ComboBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="text-muted" text="Pequeña Descripcion " />
                                                <TextArea fx:id="descripcionArea" prefHeight="80.0" promptText="Describe the gameplay experience..." styleClass="text-input-custom" wrapText="true" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" prefHeight="80.0" style="-fx-border-color: #4d4354; -fx-border-style: dashed; -fx-border-width: 2px; -fx-border-radius: 8px;">
                                            <children>
                                                <Label styleClass="text-muted" text="📁 Drag cover art or click to browse" />
                                            </children>
                                        </VBox>

                                        <Button fx:id="registrarBtn" maxWidth="1.7976931348623157E308" onAction="#handleRegistrar" prefHeight="45.0" styleClass="btn-primary-neon" text="Registrar Producto" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- COLUMNA 2: Inventory_List -->
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Label styleClass="text-secondary-color" text="📦">
                                                    <font><Font size="18.0" /></font>
                                                </Label>
                                                <Label styleClass="text-secondary-color" text="Inventory_List">
                                                    <font><Font name="System Bold" size="20.0" /></font>
                                                </Label>
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                                    <content>
                                        <GridPane fx:id="inventoryGrid" hgap="15.0" vgap="15.0">
                                            <children>

                                                <VBox prefWidth="280.0" spacing="10.0" styleClass="game-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                    <padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding>
                                                    <children>
                                                        <HBox alignment="TOP_RIGHT" prefHeight="120.0" style="-fx-background-color: #171f33; -fx-background-radius: 8px;">
                                                            <padding><Insets right="8.0" top="8.0" /></padding>
                                                            <children>
                                                                <Label text="IN STOCK">
                                                                    <styleClass><String fx:value="badge" /><String fx:value="badge-in-stock" /></styleClass>
                                                                </Label>
                                                            </children>
                                                        </HBox>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label style="-fx-font-weight: bold; -fx-font-size: 15px;" styleClass="text-white" text="Void Hunter: Genesis" />
                                                                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                                                    <children><Label style="-fx-font-weight: bold;" styleClass="text-secondary-color" text="59.99" /></children>
                                                                </HBox>
                                                            </children>
                                                        </HBox>
                                                        <Label opacity="0.8" prefHeight="40.0" styleClass="text-muted" text="Deep-space extraction RPG featuring procedural dungeons." wrapText="true" />
                                                        <HBox alignment="CENTER_LEFT" style="-fx-border-color: #31394d transparent transparent transparent; -fx-border-width: 1px;">
                                                            <padding><Insets top="8.0" /></padding>
                                                            <children>
                                                                <Label styleClass="text-muted" text="Stock: " /><Label styleClass="text-white" text="142 units" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>

                                                <VBox prefWidth="280.0" spacing="10.0" styleClass="game-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                    <padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding>
                                                    <children>
                                                        <HBox alignment="TOP_RIGHT" opacity="0.5" prefHeight="120.0" style="-fx-background-color: #171f33; -fx-background-radius: 8px;">
                                                            <padding><Insets right="8.0" top="8.0" /></padding>
                                                            <children>
                                                                <Label text="OUT OF STOCK">
                                                                    <styleClass><String fx:value="badge" /><String fx:value="badge-out-stock" /></styleClass>
                                                                </Label>
                                                            </children>
                                                        </HBox>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label style="-fx-font-weight: bold; -fx-font-size: 15px;" styleClass="text-white" text="Neon Katana" />
                                                                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                                                    <children><Label style="-fx-font-weight: bold;" styleClass="text-secondary-color" text="34.50" /></children>
                                                                </HBox>
                                                            </children>
                                                        </HBox>
                                                        <Label opacity="0.8" prefHeight="40.0" styleClass="text-muted" text="Fast-paced cyber-slasher with a focus on parrying." wrapText="true" />
                                                        <HBox alignment="CENTER_LEFT" style="-fx-border-color: #31394d transparent transparent transparent; -fx-border-width: 1px;">
                                                            <padding><Insets top="8.0" /></padding>
                                                            <children>
                                                                <Label styleClass="text-muted" text="Stock: " /><Label style="-fx-text-fill: #ffb4ab;" text="0 units" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>

                                            </children>
                                 <columnConstraints>
                                    <ColumnConstraints />
                                    <ColumnConstraints />
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints />
                                 </rowConstraints>
                                        </GridPane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
