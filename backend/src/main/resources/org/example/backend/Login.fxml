<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane styleClass="root-pane" stylesheets="/Estilos/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="modelo.LoginController">

    <VBox alignment="CENTER" maxWidth="420" spacing="22">

        <VBox alignment="CENTER" spacing="10">
            <StackPane styleClass="header-icon-badge" />
            <Label styleClass="title-text" text="Portal del Sistema" />
            <Label styleClass="subtitle-text" text="Identifíquese para acceder al panel de control" />
        </VBox>

        <VBox spacing="18" styleClass="login-card">
            <padding>
                <Insets bottom="28" left="30" right="30" top="28" />
            </padding>

            <VBox spacing="10">
                <Label styleClass="section-label" text="SELECCIONE SU ROL" />

                <HBox alignment="CENTER" spacing="10">
                    <fx:define>
                        <ToggleGroup fx:id="rolToggleGroup" />
                    </fx:define>

                    <ToggleButton fx:id="adminToggle" maxWidth="Infinity" styleClass="role-toggle" userData="Administrador" HBox.hgrow="ALWAYS">
                        <graphic>
                            <VBox alignment="CENTER" spacing="6">
                                <SVGPath content="M12 2 4 5v6c0 5.25 3.6 10.16 8 11 4.4-.84 8-5.75 8-11V5l-8-3zm0 2.18 6 2.25V11c0 4.19-2.78 8.11-6 8.92C8.78 19.11 6 15.19 6 11V6.43l6-2.25z" styleClass="role-icon" />
                                <Label styleClass="role-label" text="Administrador" />
                            </VBox>
                        </graphic>
                  <toggleGroup>
                     <ToggleGroup fx:id="rolToggleGroup" />
                  </toggleGroup>
                    </ToggleButton>

                    <ToggleButton fx:id="empleadoToggle" maxWidth="Infinity" styleClass="role-toggle" toggleGroup="$rolToggleGroup" userData="Empleado" HBox.hgrow="ALWAYS">
                        <graphic>
                            <VBox alignment="CENTER" spacing="6">
                                <SVGPath content="M10 4h4a2 2 0 0 1 2 2v1h4a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a1 1 0 0 1 1-1h4V6a2 2 0 0 1 2-2zm0 3h4V6h-4v1zM4 9v9h16V9H4z" styleClass="role-icon" />
                                <Label styleClass="role-label" text="Empleado" />
                            </VBox>
                        </graphic>
                    </ToggleButton>

                    <ToggleButton fx:id="usuarioToggle" maxWidth="Infinity" styleClass="role-toggle" toggleGroup="$rolToggleGroup" userData="Usuario" HBox.hgrow="ALWAYS">
                        <graphic>
                            <VBox alignment="CENTER" spacing="6">
                                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" styleClass="role-icon" />
                                <Label styleClass="role-label" text="Usuario" />
                            </VBox>
                        </graphic>
                    </ToggleButton>
                </HBox>
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="Nombre de Usuario" />
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                    <SVGPath content="M12 12c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3zm0 2c-2.03 0-3.68.68-4.5 1.5C6.5 16.85 6 18 6 18h12s-.5-1.15-1.5-2.5c-.82-.82-2.47-1.5-4.5-1.5z" styleClass="input-icon" />
                    <TextField fx:id="usuarioField" promptText="ej: jsmith_01" styleClass="borderless-input" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <VBox spacing="6">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="field-label" text="Contraseña" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Hyperlink onAction="#handleOlvidoContrasena" styleClass="forgot-link" text="¿Olvidó su contraseña?" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                    <SVGPath content="M12 17a2 2 0 0 0 2-2 2 2 0 0 0-2-2 2 2 0 0 0-2 2 2 2 0 0 0 2 2zm6-9h-1V6a5 5 0 0 0-10 0v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2zM8.9 6a3.1 3.1 0 0 1 6.2 0v2H8.9V6z" styleClass="input-icon" />

                    <PasswordField fx:id="passwordField" promptText="********" styleClass="borderless-input" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <Label fx:id="mensajeErrorLabel" managed="false" styleClass="error-label" visible="false" wrapText="true" />

            <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" styleClass="primary-button">
                <graphic>
                    <HBox alignment="CENTER" spacing="8">
                        <Label styleClass="primary-button-text" text="Iniciar Sesión" />
                        <SVGPath content="M5 12h13M13 6l6 6-6 6" styleClass="button-arrow-icon" />
                    </HBox>
                </graphic>
            </Button>

        </VBox>
    </VBox>

</StackPane>
