<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane styleClass="root-pane" stylesheets="/Estilos/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="modelo.LoginController">

    <VBox alignment="CENTER" maxWidth="420" spacing="22">

        <VBox alignment="CENTER" spacing="10">
            <StackPane styleClass="header-icon-badge" />
            <Label styleClass="title-text" text="Portal del Sistema" />
            <Label styleClass="subtitle-text" text="Identifíquese para acceder al panel de control" />
        </VBox>

        <VBox spacing="18" styleClass="login-card">
            <padding>
                <Insets bottom="28" left="30" right="30" top="28" />
            </padding>

            <VBox spacing="6">
                <Label styleClass="field-label" text="Nombre de Usuario" />
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                    <SVGPath content="M12 12c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3zm0 2c-2.03 0-3.68.68-4.5 1.5C6.5 16.85 6 18 6 18h12s-.5-1.15-1.5-2.5c-.82-.82-2.47-1.5-4.5-1.5z" styleClass="input-icon" />
                    <TextField fx:id="usuarioField" promptText="ej: jsmith_01" styleClass="borderless-input" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <VBox spacing="6">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="field-label" text="Contrasena" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="forgot-link" text="" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="input-wrapper">
                    <SVGPath content="M12 17a2 2 0 0 0 2-2 2 2 0 0 0-2-2 2 2 0 0 0-2 2 2 2 0 0 0 2 2zm6-9h-1V6a5 5 0 0 0-10 0v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2zM8.9 6a3.1 3.1 0 0 1 6.2 0v2H8.9V6z" styleClass="input-icon" />

                    <PasswordField fx:id="passwordField" promptText="********" styleClass="borderless-input" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <Label fx:id="mensajeErrorLabel" managed="false" styleClass="error-label" visible="false" wrapText="true" />

            <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" styleClass="primary-button">
                <graphic>
                    <HBox alignment="CENTER" spacing="8">
                        <Label styleClass="primary-button-text" text="Iniciar Sesion" />
                        <SVGPath content="M5 12h13M13 6l6 6-6 6" styleClass="button-arrow-icon" />
                    </HBox>
                </graphic>
            </Button>

        </VBox>
    </VBox>

</StackPane>
